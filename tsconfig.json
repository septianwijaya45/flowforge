{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./frontend/src/*"]
        },
        "jsx": "react-jsx"
    },
    "include": ["frontend/src/**/*.ts", "frontend/src/**/*.tsx"],
    "exclude": ["frontend/node_modules", "frontend/dist"]
}
